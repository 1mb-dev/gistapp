---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Base title="Privacy — Gist">
  <SiteHeader />

  <main id="main-content" class="privacy">
    <div class="container">
      <h1 class="privacy-title">Privacy</h1>

      <section class="privacy-section">
        <h2>What we collect</h2>
        <p>
          We track anonymous, aggregate usage counters to understand how the product is used: page
          views, persona selections, spec generations, and downloads. These are simple counts with
          no personal identifiers attached.
        </p>
      </section>

      <section class="privacy-section">
        <h2>What we don't collect</h2>
        <ul>
          <li>No personal information (name, email, IP address)</li>
          <li>No cookies or tracking pixels</li>
          <li>No third-party analytics (no Google Analytics, no ad trackers)</li>
          <li>No fingerprinting or cross-site tracking</li>
        </ul>
      </section>

      <section class="privacy-section">
        <h2>Your data stays on your device</h2>
        <p>
          Your answers and generated spec are stored in your browser's session storage. They never
          leave your device unless you explicitly share a spec link, which stores the spec data on
          our server for 90 days so others can view it.
        </p>
      </section>

      <section class="privacy-section">
        <h2>Third-party services</h2>
        <p>
          The site is hosted on Cloudflare Pages. Cloudflare's privacy-respecting Web Analytics
          provides basic traffic metrics without cookies or personal data collection.
        </p>
      </section>

      <section class="privacy-section">
        <h2>Questions?</h2>
        <p>
          This project is open source. See the
          <a href="https://github.com/1mb-dev/gistapp" class="privacy-link">GitHub repository</a>
          for the full source code, or open an issue if you have questions.
        </p>
      </section>

      <a href="/" class="btn btn-ghost">Back to home</a>
    </div>
  </main>
</Base>

<style>
  .privacy {
    padding: var(--space-16) 0 var(--space-24);
  }

  .privacy-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    color: var(--color-text);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-10);
  }

  .privacy-section {
    margin-bottom: var(--space-8);
  }

  .privacy-section h2 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .privacy-section p,
  .privacy-section li {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-size: var(--text-base);
  }

  .privacy-section ul {
    list-style: disc;
    padding-left: var(--space-6);
  }

  .privacy-section li {
    margin-bottom: var(--space-2);
  }

  .privacy-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .privacy-link:hover {
    color: var(--color-accent-hover);
  }
</style>
