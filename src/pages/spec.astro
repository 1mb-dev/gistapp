---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Base title="Your spec — Gist">
  <SiteHeader />

  <main id="main-content">
    <!-- No answers state -->
    <section id="no-answers" class="no-answers-section" hidden>
      <div class="container">
        <h1 class="page-title">No spec to show</h1>
        <p class="page-subtitle">You haven't completed the questions yet.</p>
        <a href="/create" class="btn btn-primary">Start creating your spec</a>
      </div>
    </section>

    <!-- Spec preview -->
    <section id="spec-preview-section" class="spec-preview-section" hidden>
      <div class="container">
        <div class="spec-header">
          <h1 class="page-title" id="spec-title">Your spec</h1>
          <p class="spec-meta" id="spec-meta-line"></p>
        </div>

        <div class="spec-actions-top">
          <button id="btn-download" class="btn btn-primary" type="button"> Download .md </button>
          <button id="btn-copy" class="btn btn-ghost" type="button"> Copy to clipboard </button>
        </div>

        <div class="spec-preview-window">
          <div class="spec-preview-bar">
            <span class="spec-dot"></span>
            <span class="spec-dot"></span>
            <span class="spec-dot"></span>
            <span class="spec-filename" id="spec-filename"></span>
          </div>
          <pre class="spec-body" id="spec-body"><code id="spec-code" /></pre>
        </div>

        <div class="spec-actions-bottom">
          <button id="btn-download-2" class="btn btn-primary" type="button"> Download .md </button>
          <button id="btn-copy-2" class="btn btn-ghost" type="button"> Copy to clipboard </button>
        </div>
      </div>
    </section>

    <!-- What's Next -->
    <section id="whats-next" class="whats-next-section" hidden>
      <div class="container">
        <h2 class="section-title">What's next</h2>

        <ol class="next-steps">
          <li class="next-step">
            <span class="step-number">1</span>
            <div class="step-content">
              <h3>Open your AI assistant</h3>
              <p>Claude, Cursor, Codex, or your preferred AI coding tool.</p>
            </div>
          </li>
          <li class="next-step">
            <span class="step-number">2</span>
            <div class="step-content">
              <h3>Paste the spec</h3>
              <p>Upload the markdown file or paste it directly into the chat.</p>
            </div>
          </li>
          <li class="next-step">
            <span class="step-number">3</span>
            <div class="step-content">
              <h3>Use the suggested prompt</h3>
              <p>
                Your spec includes a ready-made prompt at the bottom. Copy and paste it to get
                started.
              </p>
            </div>
          </li>
        </ol>

        <div class="prompt-preview">
          <h3 class="prompt-label">Your suggested prompt:</h3>
          <div class="prompt-box" id="prompt-box"></div>
          <button id="btn-copy-prompt" class="btn btn-ghost btn-sm" type="button">
            Copy prompt
          </button>
        </div>
      </div>
    </section>

    <!-- Feedback -->
    <section id="feedback-section" class="feedback-section" hidden>
      <div class="container">
        <h2 class="feedback-title">How was that?</h2>
        <p class="feedback-subtitle">Quick feedback helps us improve Gist.</p>
        <div class="feedback-options" role="radiogroup" aria-label="Rate your experience">
          <button class="feedback-btn" data-feedback="great" type="button">
            <span class="feedback-emoji" aria-hidden="true">&#x1F44D;</span>
            <span>Great</span>
          </button>
          <button class="feedback-btn" data-feedback="okay" type="button">
            <span class="feedback-emoji" aria-hidden="true">&#x1F937;</span>
            <span>Okay</span>
          </button>
          <button class="feedback-btn" data-feedback="needs-work" type="button">
            <span class="feedback-emoji" aria-hidden="true">&#x1F4AD;</span>
            <span>Needs work</span>
          </button>
        </div>
        <p id="feedback-thanks" class="feedback-thanks" hidden>Thanks for the feedback!</p>
      </div>
    </section>

    <!-- Start over -->
    <section id="start-over" class="start-over-section" hidden>
      <div class="container">
        <a href="/create" class="btn btn-ghost">Create another spec</a>
        <a href="/" class="btn btn-ghost">Back to home</a>
      </div>
    </section>
  </main>
</Base>

<script>
  import { generateSpec, generateFilename, extractSuggestedPrompt } from '../lib/generator';
  import type { UserAnswers } from '../lib/types';
  import { determineComplexity, tierDescriptions } from '../lib/complexity';
  import { track } from '../lib/insights';

  // --- Load answers from sessionStorage ---
  let raw: string | null = null;
  try {
    raw = sessionStorage.getItem('gist-answers');
  } catch {
    // sessionStorage blocked (private browsing, storage disabled, etc.)
  }
  const noAnswers = document.getElementById('no-answers')!;
  const specSection = document.getElementById('spec-preview-section')!;
  const whatsNext = document.getElementById('whats-next')!;
  const feedbackSection = document.getElementById('feedback-section')!;
  const startOver = document.getElementById('start-over')!;

  if (!raw) {
    noAnswers.hidden = false;
  } else {
    let answers: Partial<UserAnswers> | null = null;
    try {
      answers = JSON.parse(raw);
    } catch {
      noAnswers.hidden = false;
      const title = noAnswers.querySelector('.page-title');
      if (title) title.textContent = 'Something went wrong';
      const subtitle = noAnswers.querySelector('.page-subtitle');
      if (subtitle)
        subtitle.textContent =
          'Your answers couldn\u2019t be loaded. Please try creating your spec again.';
      sessionStorage.removeItem('gist-answers');
    }

    if (answers) {
      try {
        const spec = generateSpec(answers);
        const filename = generateFilename(answers);
        const tier = determineComplexity(answers);
        const tierInfo = tierDescriptions[tier as keyof typeof tierDescriptions];

        // Show sections
        specSection.hidden = false;
        whatsNext.hidden = false;
        feedbackSection.hidden = false;
        startOver.hidden = false;

        // Populate spec title and meta
        const specTitle = document.getElementById('spec-title')!;
        specTitle.textContent = `${answers.title ?? 'Your'} spec`;

        const metaLine = document.getElementById('spec-meta-line')!;
        metaLine.textContent = `${tierInfo.label} tier \u00b7 ${tierInfo.framework}`;

        // Filename
        const filenameEl = document.getElementById('spec-filename')!;
        filenameEl.textContent = filename;

        // Spec body
        const specCode = document.getElementById('spec-code')!;
        specCode.textContent = spec;

        // Extract suggested prompt for the prompt preview
        const promptBox = document.getElementById('prompt-box')!;
        promptBox.textContent = extractSuggestedPrompt(spec);

        // --- Actions ---

        function downloadSpec(): void {
          track('spec_downloaded', { tier });
          try {
            const blob = new Blob([spec], { type: 'text/markdown' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
          } catch (err) {
            console.error('[spec] Download failed:', err);
            const btns = document.querySelectorAll<HTMLButtonElement>(
              '#btn-download, #btn-download-2',
            );
            btns.forEach((btn) => {
              const original = btn.textContent;
              btn.textContent = 'Download failed \u2014 try again';
              setTimeout(() => {
                btn.textContent = original;
              }, 3000);
            });
          }
        }

        async function copySpec(button: HTMLButtonElement): Promise<void> {
          track('spec_copied', { tier });
          const original = button.textContent;
          try {
            await navigator.clipboard.writeText(spec);
            button.textContent = 'Copied!';
            setTimeout(() => {
              button.textContent = original;
            }, 2000);
          } catch {
            // Fallback: select the spec text so user can Cmd+C / Ctrl+C
            const range = document.createRange();
            range.selectNodeContents(specCode);
            const sel = window.getSelection();
            sel?.removeAllRanges();
            sel?.addRange(range);
            button.textContent = 'Selected \u2014 press Ctrl+C to copy';
            setTimeout(() => {
              button.textContent = original;
            }, 3000);
          }
        }

        // Download buttons
        document.getElementById('btn-download')!.addEventListener('click', downloadSpec);
        document.getElementById('btn-download-2')!.addEventListener('click', downloadSpec);

        // Copy buttons
        const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
        const btnCopy2 = document.getElementById('btn-copy-2') as HTMLButtonElement;
        btnCopy.addEventListener('click', () => copySpec(btnCopy));
        btnCopy2.addEventListener('click', () => copySpec(btnCopy2));

        // Copy prompt
        const btnCopyPrompt = document.getElementById('btn-copy-prompt') as HTMLButtonElement;
        btnCopyPrompt.addEventListener('click', async () => {
          track('prompt_copied', { tier });
          try {
            await navigator.clipboard.writeText(promptBox.textContent ?? '');
            const original = btnCopyPrompt.textContent;
            btnCopyPrompt.textContent = 'Copied!';
            setTimeout(() => {
              btnCopyPrompt.textContent = original;
            }, 2000);
          } catch {
            // Fallback: select the text so user can Cmd+C / Ctrl+C
            const range = document.createRange();
            range.selectNodeContents(promptBox);
            const sel = window.getSelection();
            sel?.removeAllRanges();
            sel?.addRange(range);
            btnCopyPrompt.textContent = 'Select and copy manually';
            setTimeout(() => {
              btnCopyPrompt.textContent = 'Copy prompt';
            }, 3000);
          }
        });

        // Feedback
        const feedbackBtns = document.querySelectorAll<HTMLButtonElement>('.feedback-btn');
        const feedbackThanks = document.getElementById('feedback-thanks')!;

        feedbackBtns.forEach((btn) => {
          btn.addEventListener('click', () => {
            const feedback = btn.dataset.feedback;
            track('feedback', { feedback: feedback ?? '', tier });
            // Store locally as fallback
            try {
              const feedbackRaw = localStorage.getItem('gist-feedback') ?? '[]';
              let existing: unknown[];
              try {
                existing = JSON.parse(feedbackRaw);
                if (!Array.isArray(existing)) existing = [];
              } catch {
                console.warn('[spec] Corrupt feedback data, resetting');
                existing = [];
              }
              existing.push({ feedback, timestamp: new Date().toISOString(), tier });
              localStorage.setItem('gist-feedback', JSON.stringify(existing));
            } catch {
              /* storage inaccessible — feedback still sent via beacon */
            }

            feedbackBtns.forEach((b) => {
              b.disabled = true;
            });
            feedbackThanks.hidden = false;
          });
        });
      } catch (err) {
        console.error('[spec] Generation failed:', err);
        noAnswers.hidden = false;
        const title = noAnswers.querySelector('.page-title');
        if (title) title.textContent = 'Spec generation failed';
        const subtitle = noAnswers.querySelector('.page-subtitle');
        if (subtitle)
          subtitle.textContent =
            'Something went wrong while building your spec. Please try creating it again.';
      }
    } /* end if(answers) after parse */
  }
</script>

<style is:global>
  /* No answers */
  .no-answers-section {
    padding: var(--space-20) 0;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3);
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  /* Spec preview */
  .spec-preview-section {
    padding: var(--space-8) 0;
  }

  .spec-header {
    margin-bottom: var(--space-6);
  }

  .spec-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin-top: var(--space-2);
  }

  .spec-actions-top,
  .spec-actions-bottom {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .spec-actions-bottom {
    margin-top: var(--space-6);
    margin-bottom: 0;
  }

  .spec-preview-window {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .spec-preview-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--color-bg-sunken);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .spec-dot {
    width: 9px;
    height: 9px;
    border-radius: var(--radius-full);
  }

  .spec-dot:nth-child(1) {
    background: #e5534b;
    opacity: 0.65;
  }
  .spec-dot:nth-child(2) {
    background: #d4a72c;
    opacity: 0.65;
  }
  .spec-dot:nth-child(3) {
    background: #3fb950;
    opacity: 0.65;
  }

  .spec-filename {
    margin-left: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }

  .spec-body {
    padding: var(--space-6);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    background: var(--color-bg-raised);
    border: none;
    margin: 0;
    max-height: 600px;
    overflow-y: auto;
  }

  .spec-body code {
    background: none;
    padding: 0;
    font-size: inherit;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Button size variants (extends global .btn) */
  .btn-sm {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
    min-height: 44px;
  }

  /* What's Next */
  .whats-next-section {
    padding: var(--space-16) 0;
    background: var(--color-bg-sunken);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-10);
  }

  .next-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 480px;
    margin-bottom: var(--space-12);
  }

  .next-step {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .prompt-preview {
    max-width: 560px;
  }

  .prompt-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-3);
    letter-spacing: var(--tracking-wide);
  }

  .prompt-box {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    white-space: pre-wrap;
    margin-bottom: var(--space-3);
    box-shadow: var(--shadow-sm);
  }

  /* Feedback */
  .feedback-section {
    padding: var(--space-12) 0;
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .feedback-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-normal);
    margin-bottom: var(--space-2);
    letter-spacing: var(--tracking-tight);
  }

  .feedback-subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .feedback-options {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .feedback-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--color-bg-raised);
    border: 1.5px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    cursor: pointer;
    font-family: inherit;
    font-size: var(--text-sm);
    color: var(--color-text);
    transition: all var(--duration-normal) var(--easing);
    min-height: 44px;
    min-width: 96px;
    box-shadow: var(--shadow-card);
  }

  .feedback-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-1px);
  }

  .feedback-btn:active:not(:disabled) {
    transform: translateY(0.5px);
  }

  .feedback-btn:disabled {
    opacity: 0.5;
    cursor: default;
    transform: none;
  }

  .feedback-emoji {
    font-size: var(--text-xl);
  }

  .feedback-thanks {
    margin-top: var(--space-5);
    color: var(--color-status-success);
    font-weight: var(--weight-medium);
  }

  /* Start over */
  .start-over-section {
    padding: var(--space-10) 0 var(--space-20);
    text-align: center;
  }

  .start-over-section .container {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .section-title {
      font-size: var(--text-3xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn,
    .feedback-btn {
      transition: none;
    }
  }
</style>
