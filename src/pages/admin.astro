---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Base title="Admin — Gist" description="Gist analytics dashboard" noindex>
  <SiteHeader />

  <main id="main-content">
    <section class="admin-section">
      <div class="container">
        <h1 class="admin-title">Insights</h1>

        <div id="auth-form" class="auth-form">
          <label for="admin-token" class="field-label">Admin token</label>
          <div class="auth-row">
            <input
              type="password"
              id="admin-token"
              class="field-input"
              placeholder="Enter your admin token"
              autocomplete="off"
            />
            <button id="btn-load" class="btn btn-primary" type="button">Load stats</button>
          </div>
        </div>

        <div id="loading" class="loading-state" hidden>
          <div class="spinner"></div>
          <p>Loading stats...</p>
        </div>

        <div id="error-state" class="error-state" hidden>
          <p id="error-message"></p>
          <button id="btn-retry" class="btn btn-ghost" type="button">Try again</button>
        </div>

        <div id="empty-state" class="empty-state" hidden>
          <p>No data yet. Events will appear here once users interact with Gist.</p>
        </div>

        <div id="stats-container" class="stats-container" hidden>
          <div class="period-selector" role="group" aria-label="Time period">
            <button class="period-btn" data-days="1" type="button">24h</button>
            <button class="period-btn" data-days="7" type="button">7d</button>
            <button class="period-btn active" data-days="30" type="button">30d</button>
          </div>

          <div class="dashboard-grid">
            <div class="panel panel-full" id="panel-funnel">
              <h2 class="panel-title">Funnel</h2>
              <div class="panel-body" id="funnel-body"></div>
              <p class="panel-insight" id="funnel-insight"></p>
            </div>

            <div class="panel panel-full" id="panel-tiers">
              <h2 class="panel-title">Tier split</h2>
              <div class="panel-body" id="tiers-body"></div>
            </div>

            <div class="panel" id="panel-satisfaction">
              <h2 class="panel-title">Satisfaction</h2>
              <div class="panel-body" id="satisfaction-body"></div>
            </div>

            <div class="panel" id="panel-actions">
              <h2 class="panel-title">After download</h2>
              <div class="panel-body" id="actions-body"></div>
              <p class="panel-insight" id="actions-insight"></p>
            </div>

            <div class="panel panel-full" id="panel-persona-tier">
              <h2 class="panel-title">Persona × Tier matrix</h2>
              <div class="panel-body" id="persona-tier-body"></div>
              <p class="panel-insight" id="persona-tier-insight"></p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>

<script>
  import { INSIGHTS_URL } from '../lib/config';

  const tokenInput = document.getElementById('admin-token') as HTMLInputElement;
  const btnLoad = document.getElementById('btn-load') as HTMLButtonElement;
  const btnRetry = document.getElementById('btn-retry') as HTMLButtonElement;
  const loading = document.getElementById('loading')!;
  const errorState = document.getElementById('error-state')!;
  const errorMessage = document.getElementById('error-message')!;
  const emptyState = document.getElementById('empty-state')!;
  const statsContainer = document.getElementById('stats-container')!;
  const authForm = document.getElementById('auth-form')!;

  tokenInput.addEventListener('input', () => {
    tokenInput.removeAttribute('aria-invalid');
  });

  type StatsResponse = Record<string, Record<string, number>>;

  let isLoading = false;
  let fullData: StatsResponse = {};
  let activeDays = 30;

  function get(day: Record<string, number> | undefined, key: string): number {
    return day?.[key] ?? 0;
  }

  function filterByPeriod(data: StatsResponse, days: number): StatsResponse {
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - days);
    const cutoffStr = cutoff.toISOString().slice(0, 10);
    const filtered: StatsResponse = {};
    for (const [date, values] of Object.entries(data)) {
      if (date >= cutoffStr) filtered[date] = values;
    }
    return filtered;
  }

  function sumMetric(data: StatsResponse, key: string): number {
    let total = 0;
    for (const day of Object.values(data)) {
      total += get(day, key);
    }
    return total;
  }

  function pct(part: number, whole: number): string {
    if (whole === 0) return '0%';
    return Math.round((part / whole) * 100) + '%';
  }

  function createMetricBar(label: string, value: number, max: number, color?: string): HTMLElement {
    const bar = document.createElement('div');
    bar.className = 'metric-bar';

    const labelEl = document.createElement('span');
    labelEl.className = 'metric-bar-label';
    labelEl.textContent = label;

    const track = document.createElement('div');
    track.className = 'metric-bar-track';

    const fill = document.createElement('div');
    fill.className = 'metric-bar-fill';
    const width = max === 0 ? 0 : Math.round((value / max) * 100);
    fill.style.width = `${width}%`;
    if (color) fill.style.background = color;
    track.appendChild(fill);

    const valueEl = document.createElement('span');
    valueEl.className = 'metric-bar-value';
    valueEl.textContent = String(value);

    bar.appendChild(labelEl);
    bar.appendChild(track);
    bar.appendChild(valueEl);
    return bar;
  }

  function renderFunnel(data: StatsResponse): void {
    const body = document.getElementById('funnel-body')!;
    const insight = document.getElementById('funnel-insight')!;
    body.replaceChildren();

    const visited = sumMetric(data, 'page_viewed');
    const persona = sumMetric(data, 'persona_selected');
    const generated = sumMetric(data, 'spec_generated');
    const downloaded = sumMetric(data, 'spec_downloaded');

    const max = Math.max(visited, persona, generated, downloaded, 1);

    const steps = [
      { label: 'Visited', value: visited },
      { label: 'Persona', value: persona },
      { label: 'Generated', value: generated },
      { label: 'Downloaded', value: downloaded },
    ];

    for (const s of steps) {
      body.appendChild(createMetricBar(`${s.label} (${pct(s.value, visited)})`, s.value, max));
    }

    let biggestDrop = 0;
    let dropFrom = '';
    let dropTo = '';
    let dropPct = '0%';
    for (let i = 0; i < steps.length - 1; i++) {
      const drop = steps[i].value - steps[i + 1].value;
      if (drop > biggestDrop && steps[i].value > 0) {
        biggestDrop = drop;
        dropFrom = steps[i].label;
        dropTo = steps[i + 1].label;
        dropPct = pct(drop, steps[i].value);
      }
    }

    insight.textContent =
      biggestDrop > 0 ? `Biggest drop: ${dropFrom} \u2192 ${dropTo} (${dropPct})` : '';
  }

  function renderTiers(data: StatsResponse): void {
    const body = document.getElementById('tiers-body')!;
    body.replaceChildren();

    const minimal = sumMetric(data, 'spec_generated:minimal');
    const standard = sumMetric(data, 'spec_generated:standard');
    const full = sumMetric(data, 'spec_generated:full');
    const tierTotal = minimal + standard + full;
    const tierMax = Math.max(minimal, standard, full, 1);

    const newBuilder = sumMetric(data, 'persona_selected:new-builder');
    const developer = sumMetric(data, 'persona_selected:developer');
    const personaTotal = newBuilder + developer;
    const personaMax = Math.max(newBuilder, developer, 1);

    const split = document.createElement('div');
    split.className = 'tiers-split';

    // Tiers column
    const tiersCol = document.createElement('div');
    tiersCol.className = 'tiers-column';
    const tiersH = document.createElement('h3');
    tiersH.className = 'tiers-heading';
    tiersH.textContent = 'Tiers';
    tiersCol.appendChild(tiersH);
    tiersCol.appendChild(
      createMetricBar(
        `Minimal (${pct(minimal, tierTotal)})`,
        minimal,
        tierMax,
        'var(--color-status-success)',
      ),
    );
    tiersCol.appendChild(
      createMetricBar(
        `Standard (${pct(standard, tierTotal)})`,
        standard,
        tierMax,
        'var(--color-accent)',
      ),
    );
    tiersCol.appendChild(
      createMetricBar(
        `Full (${pct(full, tierTotal)})`,
        full,
        tierMax,
        'var(--color-status-warning)',
      ),
    );
    split.appendChild(tiersCol);

    // Personas column
    const personaCol = document.createElement('div');
    personaCol.className = 'tiers-column';
    const personaH = document.createElement('h3');
    personaH.className = 'tiers-heading';
    personaH.textContent = 'Personas';
    personaCol.appendChild(personaH);
    personaCol.appendChild(
      createMetricBar(`New builder (${pct(newBuilder, personaTotal)})`, newBuilder, personaMax),
    );
    personaCol.appendChild(
      createMetricBar(`Developer (${pct(developer, personaTotal)})`, developer, personaMax),
    );
    split.appendChild(personaCol);

    body.appendChild(split);
  }

  function renderSatisfaction(data: StatsResponse): void {
    const body = document.getElementById('satisfaction-body')!;
    body.replaceChildren();

    const great = sumMetric(data, 'feedback:great');
    const okay = sumMetric(data, 'feedback:okay');
    const needsWork = sumMetric(data, 'feedback:needs-work');
    const total = great + okay + needsWork;

    if (total < 3) {
      const empty = document.createElement('p');
      empty.className = 'panel-empty';
      empty.textContent = 'Not enough data';
      body.appendChild(empty);
      return;
    }

    const greatPct = Math.round((great / total) * 100);
    const okayPct = Math.round((okay / total) * 100);
    const needsPct = 100 - greatPct - okayPct;
    const max = Math.max(great, okay, needsWork, 1);

    const number = document.createElement('div');
    number.className = 'satisfaction-number';
    number.textContent = `${greatPct}%`;

    const label = document.createElement('div');
    label.className = 'satisfaction-label';
    label.textContent = 'rated great';

    const donut = document.createElement('div');
    donut.className = 'satisfaction-donut';
    donut.style.background = `conic-gradient(var(--color-status-success) 0% ${greatPct}%, var(--color-accent) ${greatPct}% ${greatPct + okayPct}%, var(--color-status-warning) ${greatPct + okayPct}% 100%)`;

    const breakdown = document.createElement('div');
    breakdown.className = 'satisfaction-breakdown';
    breakdown.appendChild(
      createMetricBar(`Great (${greatPct}%)`, great, max, 'var(--color-status-success)'),
    );
    breakdown.appendChild(createMetricBar(`Okay (${okayPct}%)`, okay, max, 'var(--color-accent)'));
    breakdown.appendChild(
      createMetricBar(`Needs work (${needsPct}%)`, needsWork, max, 'var(--color-status-warning)'),
    );

    body.appendChild(number);
    body.appendChild(label);
    body.appendChild(donut);
    body.appendChild(breakdown);
  }

  function renderActions(data: StatsResponse): void {
    const body = document.getElementById('actions-body')!;
    const insight = document.getElementById('actions-insight')!;
    body.replaceChildren();

    const downloaded = sumMetric(data, 'spec_downloaded');
    const copied = sumMetric(data, 'spec_copied');
    const promptCopied = sumMetric(data, 'prompt_copied');
    const max = Math.max(downloaded, copied, promptCopied, 1);

    body.appendChild(createMetricBar('Downloaded', downloaded, max));
    body.appendChild(createMetricBar('Copied', copied, max));
    body.appendChild(createMetricBar('Prompt copied', promptCopied, max));

    const total = downloaded + copied + promptCopied;
    if (total > 0) {
      const topAction =
        downloaded >= copied && downloaded >= promptCopied
          ? 'download'
          : copied >= promptCopied
            ? 'copy'
            : 'prompt copy';
      insight.textContent = `Most common action: ${topAction}`;
    } else {
      insight.textContent = '';
    }
  }

  function renderPersonaTierMatrix(data: StatsResponse): void {
    const body = document.getElementById('persona-tier-body')!;
    const insight = document.getElementById('persona-tier-insight')!;
    body.replaceChildren();

    // Parse composite keys: "spec_generated:persona:tier"
    const matrix: Record<string, Record<string, number>> = {};

    for (const day of Object.values(data)) {
      for (const [key, count] of Object.entries(day)) {
        const parts = key.split(':');
        if (parts[0] === 'spec_generated' && parts.length === 4) {
          const [, , persona, tier] = parts;
          if (!matrix[persona]) matrix[persona] = {};
          matrix[persona][tier] = (matrix[persona][tier] ?? 0) + count;
        }
      }
    }

    // If no composite data, show empty state
    if (Object.keys(matrix).length === 0) {
      const empty = document.createElement('p');
      empty.className = 'panel-empty';
      empty.textContent = 'No persona×tier data yet.';
      body.appendChild(empty);
      return;
    }

    // Render as stacked bars per tier
    const tiers = ['minimal', 'standard', 'full'];
    const personas = Object.keys(matrix);

    for (const tier of tiers) {
      const tierCol = document.createElement('div');
      tierCol.className = 'tier-section';

      const tierLabel = document.createElement('h3');
      tierLabel.className = 'tier-label';
      tierLabel.textContent = tier.charAt(0).toUpperCase() + tier.slice(1);
      tierCol.appendChild(tierLabel);

      let tierTotal = 0;
      for (const persona of personas) {
        tierTotal += matrix[persona]?.[tier] ?? 0;
      }

      for (const persona of personas) {
        const count = matrix[persona]?.[tier] ?? 0;
        tierCol.appendChild(
          createMetricBar(
            `${persona} (${pct(count, tierTotal)})`,
            count,
            Math.max(...personas.map((p) => matrix[p]?.[tier] ?? 0)) || 1,
          ),
        );
      }

      body.appendChild(tierCol);
    }

    // Insight: which persona×tier combo is most common
    let topCombo = '';
    let topCount = 0;
    for (const [persona, tiers] of Object.entries(matrix)) {
      for (const [tier, count] of Object.entries(tiers)) {
        if (count > topCount) {
          topCount = count;
          topCombo = `${persona}-${tier}`;
        }
      }
    }

    insight.textContent = topCombo ? `Most common: ${topCombo} (${topCount})` : '';
  }

  function renderDashboard(data: StatsResponse): void {
    const dates = Object.keys(data);
    const hasFullData = Object.keys(fullData).length > 0;

    if (dates.length === 0) {
      if (hasFullData) {
        // Data exists in other periods, but not in the selected one
        const periodLabel = activeDays === 1 ? '24 hours' : activeDays === 7 ? '7 days' : '30 days';
        emptyState.querySelector('p')!.textContent =
          `No events in the last ${periodLabel}. Try a longer period.`;
      } else {
        emptyState.querySelector('p')!.textContent =
          'No data yet. Events will appear here once users interact with Gist.';
      }
      emptyState.hidden = false;
      statsContainer.hidden = true;
      return;
    }

    emptyState.hidden = true;
    statsContainer.hidden = false;

    renderFunnel(data);
    renderTiers(data);
    renderSatisfaction(data);
    renderActions(data);
    renderPersonaTierMatrix(data);
  }

  // Period selector
  document.querySelectorAll<HTMLButtonElement>('.period-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.period-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeDays = Number(btn.dataset.days);
      renderDashboard(filterByPeriod(fullData, activeDays));
    });
  });

  async function loadStats(): Promise<void> {
    if (isLoading) return;

    const token = tokenInput.value.trim();
    if (!token) {
      tokenInput.setAttribute('aria-invalid', 'true');
      tokenInput.focus();
      return;
    }
    tokenInput.removeAttribute('aria-invalid');

    isLoading = true;
    btnLoad.disabled = true;
    btnLoad.textContent = 'Loading...';
    loading.hidden = false;
    errorState.hidden = true;
    emptyState.hidden = true;
    statsContainer.hidden = true;

    try {
      const res = await fetch(`${INSIGHTS_URL}/api/stats?days=30`, {
        headers: { Authorization: `Bearer ${token}` },
      });

      if (res.status === 401) {
        throw new Error('Invalid token. Check your admin token and try again.');
      }

      if (!res.ok) {
        throw new Error(`Server error (${res.status}). Try again later.`);
      }

      fullData = await res.json();
      renderDashboard(filterByPeriod(fullData, activeDays));
      authForm.hidden = true;
      btnLoad.disabled = false;
      btnLoad.textContent = 'Load stats';
    } catch (err) {
      btnLoad.disabled = false;
      btnLoad.textContent = 'Load stats';
      errorState.hidden = false;
      if (err instanceof TypeError) {
        errorMessage.textContent =
          'Could not reach the analytics server. Check your connection and verify the worker is deployed.';
      } else if (err instanceof SyntaxError) {
        errorMessage.textContent =
          'Received an unexpected response from the server. The worker may be misconfigured.';
      } else {
        errorMessage.textContent =
          err instanceof Error ? err.message : 'Failed to load stats. Check your connection.';
      }
    } finally {
      isLoading = false;
      loading.hidden = true;
    }
  }

  btnLoad.addEventListener('click', loadStats);
  btnRetry.addEventListener('click', () => {
    errorState.hidden = true;
    authForm.hidden = false;
    btnLoad.disabled = false;
    btnLoad.textContent = 'Load stats';
    tokenInput.focus();
  });

  tokenInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') loadStats();
  });
</script>

<style is:global>
  .admin-section {
    padding: var(--space-8) 0 var(--space-20);
  }

  .admin-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-8);
  }

  .auth-form {
    max-width: 480px;
    margin-bottom: var(--space-8);
  }

  .auth-row {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .auth-row .field-input {
    flex: 1;
  }

  .field-input[aria-invalid='true'] {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  .loading-state {
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8) 0;
    color: var(--color-text-secondary);
  }

  .loading-state:not([hidden]) {
    display: flex;
  }

  .loading-state .spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: var(--radius-full);
    animation: spin 0.9s linear infinite;
  }

  .error-state {
    padding: var(--space-6);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border-subtle);
    border-left: 3px solid var(--color-status-error, #e5534b);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-8);
  }

  .error-state p {
    color: var(--color-status-error, #e5534b);
    margin-bottom: var(--space-3);
  }

  .empty-state {
    padding: var(--space-12) 0;
    text-align: center;
    color: var(--color-text-muted);
  }

  /* Period selector */
  .period-selector {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .period-btn {
    padding: var(--space-2) var(--space-4);
    min-height: 44px;
    min-width: 44px;
    border: 1.5px solid var(--color-border-subtle);
    border-radius: var(--radius-full);
    background: var(--color-bg-raised);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    cursor: pointer;
    transition: all var(--duration-fast) var(--easing);
  }

  .period-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .period-btn.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-text);
  }

  /* Dashboard grid */
  .dashboard-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 1fr 1fr;
    }

    .panel-full {
      grid-column: 1 / -1;
    }
  }

  /* Panels */
  .panel {
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-card);
  }

  .panel-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
  }

  .panel-insight {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
    font-style: italic;
  }

  .panel-empty {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-align: center;
    padding: var(--space-6) 0;
  }

  /* Metric bars */
  .metric-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .metric-bar:last-child {
    margin-bottom: 0;
  }

  .metric-bar-label {
    flex: 0 0 auto;
    min-width: 140px;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .metric-bar-track {
    flex: 1;
    height: 8px;
    background: var(--color-bg-sunken);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .metric-bar-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    transition: width var(--duration-normal) var(--easing);
    min-width: 0;
  }

  .metric-bar-value {
    flex: 0 0 auto;
    min-width: 32px;
    text-align: right;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  /* Tiers split layout */
  .tiers-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .tiers-split {
      grid-template-columns: 1fr 1fr;
    }
  }

  .tiers-heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
  }

  /* Persona×Tier section */
  .tier-section {
    margin-bottom: var(--space-6);
  }

  .tier-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
  }

  /* Satisfaction */
  .satisfaction-number {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .satisfaction-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .satisfaction-donut {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .satisfaction-donut::after {
    content: '';
    position: absolute;
